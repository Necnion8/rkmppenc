FROM arm64v8/ubuntu:20.04

ARG DEBIAN_FRONTEND=noninteractive
ARG FFMPEG_DLL_REPO=https://github.com/rigaya/build_scripts.git
ARG FFMPEG_DLL_REF=master
ARG BUILD_SCRIPTS_DIR=/opt/build_scripts
ARG FFMPEG_PREFIX=/opt/build_scripts/ffmpeg_dll/build_dll/arm64/build

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      sudo \
      wget \
      curl \
      git \
      ca-certificates \
      gnupg \
      lsb-release \
      autogen \
      autoconf \
      automake \
      autopoint \
      gettext \
      make \
      patch \
      xz-utils \
      p7zip-full \
      unzip \
      bzip2 \
      python3 \
      python3-pip \
      gperf \
      nasm \
      yasm \
      opencl-headers \
      build-essential \
      cmake \
      libtool \
      pkg-config \
      meson \
      ninja-build \
      libass9 \
      libass-dev \
      openssl \
      libssl-dev \
    && python3 -m pip install --upgrade pip \
    && python3 -m pip install --upgrade meson ninja \
    && cmake --version \
    && meson --version \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN wget https://github.com/tsukumijima/mpp/releases/download/v1.5.0-1-194af18/librockchip-mpp1_1.5.0-1_arm64.deb && \
    apt-get install -y ./librockchip-mpp1_1.5.0-1_arm64.deb && \
    rm librockchip-mpp1_1.5.0-1_arm64.deb && \
    wget https://github.com/tsukumijima/mpp/releases/download/v1.5.0-1-194af18/librockchip-mpp-dev_1.5.0-1_arm64.deb && \
    apt-get install -y ./librockchip-mpp-dev_1.5.0-1_arm64.deb && \
    rm librockchip-mpp-dev_1.5.0-1_arm64.deb

RUN wget https://github.com/tsukumijima/librga-rockchip/releases/download/v2.2.0-1-e454afe/librga2_2.2.0-1_arm64.deb && \
    apt-get install -y ./librga2_2.2.0-1_arm64.deb && \
    rm librga2_2.2.0-1_arm64.deb && \
    wget https://github.com/tsukumijima/librga-rockchip/releases/download/v2.2.0-1-e454afe/librga-dev_2.2.0-1_arm64.deb && \
    apt-get install -y ./librga-dev_2.2.0-1_arm64.deb && \
    rm librga-dev_2.2.0-1_arm64.deb

ENV LD_LIBRARY_PATH=/usr/local/lib
ENV CARGO_HOME=/usr/local/cargo
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH=/usr/local/cargo/bin:$PATH

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable --no-modify-path && \
    cargo --version && rustc --version && \
    cargo install cargo-c --version '0.10.18+cargo-0.92.0' --locked && \
    (cargo-cbuild --version 2>/dev/null || true)

RUN git clone --depth 1 --branch ${FFMPEG_DLL_REF} ${FFMPEG_DLL_REPO} ${BUILD_SCRIPTS_DIR} \
    && cd ${BUILD_SCRIPTS_DIR}/ffmpeg_dll \
    && sed -i 's/\r$//' ./build_ffmpeg_dll.sh \
    && export NUMBER_OF_PROCESSORS="$(nproc)" \
    && bash ./build_ffmpeg_dll.sh --skip-src-archive --disable-pgo --v4l2-multiplanar \
    && test -f "${FFMPEG_PREFIX}/lib/pkgconfig/libavutil.pc" \
    && find "${BUILD_SCRIPTS_DIR}" -mindepth 1 -maxdepth 1 ! -path "${BUILD_SCRIPTS_DIR}/ffmpeg_dll" -exec rm -rf {} + \
    && find "${BUILD_SCRIPTS_DIR}/ffmpeg_dll" -mindepth 1 -maxdepth 1 ! -path "${BUILD_SCRIPTS_DIR}/ffmpeg_dll/build_dll" -exec rm -rf {} + \
    && find "${BUILD_SCRIPTS_DIR}/ffmpeg_dll/build_dll" -mindepth 1 -maxdepth 1 ! -path "${BUILD_SCRIPTS_DIR}/ffmpeg_dll/build_dll/arm64" -exec rm -rf {} + \
    && find "${BUILD_SCRIPTS_DIR}/ffmpeg_dll/build_dll/arm64" -mindepth 1 -maxdepth 1 ! -path "${BUILD_SCRIPTS_DIR}/ffmpeg_dll/build_dll/arm64/build" -exec rm -rf {} +

ENV FFMPEG_PREFIX=${FFMPEG_PREFIX}
ENV PKG_CONFIG_PATH=${FFMPEG_PREFIX}/lib/pkgconfig
WORKDIR /work
